  },

  "experience_memory_schema": {
    "description": "经验记忆存储格式",
    "type": "object",
    "properties": {
      "failure_memories": {
        "type": "array",
        "items": {
          "type": "object",
          "properties": {
            "question": {"type": "string"},
            "original_answer": {"type": "string"},
            "correct_answer": {"type": "string"},
            "error_type": {"type": "string"},
            "correct_trace": {"type": "array", "items": {"type": "string"}},
            "timestamp": {"type": "string", "format": "date-time"}
          }
        }
      },
      "success_hints": {
        "type": "array",
        "items": {
          "type": "object",
          "properties": {
            "question_type": {"type": "string"},
            "pattern": {"type": "string"},
            "hint": {"type": "string"}
          }
        }
      }
    }
  }
}
